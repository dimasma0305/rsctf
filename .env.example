# rsctf configuration template (required values are marked explicitly)

# HTTP bind address
RSCTF_BIND=0.0.0.0:8080
# Comma-separated proxy CIDRs allowed to set forwarded client IP headers.
# Unset trusts no proxy. Prefer an exact proxy /32 or a dedicated proxy-only network.
# RSCTF_TRUSTED_PROXY_CIDRS=192.0.2.10/32

# PostgreSQL connection string
RSCTF_DATABASE_URL=postgres://postgres:postgres@localhost:5432/rsctf
# Per-replica cap for provisioning operations that hold a DB advisory lock.
RSCTF_PROVISIONING_CONCURRENCY=4
RSCTF_REPO_SCAN_CONCURRENCY=1
# Let R=RSCTF_REPO_SCAN_CONCURRENCY and P=RSCTF_PROVISIONING_CONCURRENCY.
# The floor is 4R+2P+1 for web/engine, 4R+2P+3 for a non-VPN network owner,
# and 4R+2P+6 for a VPN owner. The default leaves extra headroom.
RSCTF_DB_MAX_CONNECTIONS=32

# Optional for explicit single-process local mode. Once configured, Redis is a
# required readiness dependency; /healthz stays unavailable while it reconnects.
# RSCTF_REDIS_URL=redis://localhost:6379
# Maximum plausible A&D flags one participation may submit immediately. The
# bucket then refills at 10 flags/second; valid range 100..3200.
RSCTF_AD_SUBMIT_BURST_FLAGS=400

# JWT signing secret — required, random, and at least 32 bytes.
RSCTF_JWT_SECRET=
# Required only while the user table is empty; generate with
# `openssl rand -hex 32` and supply it to the first administrator form.
RSCTF_BOOTSTRAP_TOKEN=
# Token lifetime in seconds (default 7 days)
RSCTF_JWT_TTL_SECS=604800
# Session cookies are Secure by default. Disable only for local plain-HTTP work.
# RSCTF_COOKIE_SECURE=false

# Blob storage root (uploaded avatars/attachments)
RSCTF_STORAGE_ROOT=./files
# Split roles refuse startup unless the operator explicitly confirms this path
# is the same shared POSIX filesystem on every replica.
# RSCTF_SHARED_STORAGE=true

# Registration policy
RSCTF_ALLOW_REGISTER=true
RSCTF_EMAIL_CONFIRM=false
RSCTF_ADMIN_CONFIRM=false
RSCTF_ACTIVE_ON_REGISTER=true
RSCTF_USE_CAPTCHA=false

# Set to 0 to skip auto-migration on startup
RSCTF_MIGRATE=1

# Log filter
RUST_LOG=info

# Directory of built frontend assets to serve (SPA). Unset = API only.
RSCTF_STATIC_DIR=web/build

# Global hard caps applied before any Docker/Kubernetes container is created.
RSCTF_CONTAINER_MAX_MEMORY_MB=4096
RSCTF_CONTAINER_MAX_CPU_COUNT=8
# Runtime selection. `auto` preserves discovery for non-VPN deployments; an
# enabled A&D VPN requires an explicit `docker` or `kubernetes` choice.
RSCTF_CONTAINER_BACKEND=auto
# Split archive builds and daemon-local immutable image IDs are denied unless
# every builder/container owner genuinely shares one Docker daemon. The
# maintained single-host Compose Docker override sets this.
# RSCTF_SHARED_DOCKER_DAEMON=true

# Optional live packet capture for A&D service containers. The singleton
# all/control/network worker needs Docker visibility plus CAP_NET_RAW.
RSCTF_TRAFFIC_CAPTURE_ENABLED=true
RSCTF_CAPTURE_DEVICE=any
RSCTF_CAPTURE_RECONCILE_SECONDS=2

# Process-based A&D/KotH checkers. Reserve this otherwise-unused numeric UID
# interval inside the runtime namespace; one UID is leased per live checker.
RSCTF_CHECKER_UID_BASE=60000
RSCTF_CHECKER_PROCESS_BUDGET=32
# RSCTF_AD_CHECKER_TIMEOUT_SECONDS=30
# RSCTF_AD_CHECKER_CONCURRENCY=64

# In-process A&D WireGuard hub. `REQUIRED` controls whether initialization
# failure aborts startup; it does not enable the hub by itself. VPN/BYOC state
# is intentionally singleton: a second VPN-enabled replica fails startup.
# RSCTF_AD_VPN_ENABLED=true
# RSCTF_AD_VPN_REQUIRED=true
# RSCTF_AD_VPN_CLIENT_CIDR=10.13.0.0/19
# RSCTF_AD_VPN_SERVICES_CIDR=10.13.40.0/24
# RSCTF_AD_VPN_SERVER_ENDPOINT=vpn.example:51820
# Non-root UID/GID used by Kubernetes challenge pods.
RSCTF_K8S_CHALLENGE_UID=10000
# Every non-migration Kubernetes-backend role requires the real cluster Service
# CIDR for A&D/KotH provisioning and checker target isolation, even without VPN.
# With VPN, it is also routed through the WireGuard hub. Label the rsctf pod as
# shown; out-of-cluster hubs instead need exact post-SNAT source CIDRs (prefer
# /32 entries) in AD_INGRESS_CIDRS.
# VPN mode additionally requires an ordinary isolated pod network namespace;
# hostNetwork and the in-process BYOC relay are not supported on Kubernetes.
# RSCTF_K8S_AD_SERVICE_CIDR=10.96.0.0/12
# RSCTF_K8S_ISOLATED_POD_NETNS=true
# RSCTF_K8S_CONTROL_NAMESPACE=rsctf-system
# RSCTF_K8S_CONTROL_POD_LABEL=app.kubernetes.io/name=rsctf
# RSCTF_K8S_AD_INGRESS_CIDRS=192.0.2.10/32

# Canonical browser origin used for CSRF checks, OAuth callbacks, and recovery links.
# Production deployments should use HTTPS. For local HTTP, also set
# RSCTF_COOKIE_SECURE=false explicitly.
# RSCTF_PUBLIC_URL=https://ctf.example
# External OAuth login (leave provider credentials unset to disable).
# RSCTF_GOOGLE_CLIENT_ID=
# RSCTF_GOOGLE_CLIENT_SECRET=
# RSCTF_DISCORD_CLIENT_ID=
# RSCTF_DISCORD_CLIENT_SECRET=
# Optional: override provider endpoints (enterprise/self-hosted IdP, or testing).
# Defaults are the real Google/Discord URLs.
# RSCTF_GOOGLE_AUTH_URL=
# RSCTF_GOOGLE_TOKEN_URL=
# RSCTF_GOOGLE_USERINFO_URL=
# RSCTF_DISCORD_AUTH_URL=
# RSCTF_DISCORD_TOKEN_URL=
# RSCTF_DISCORD_USERINFO_URL=
