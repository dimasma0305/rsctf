# Copy this file to .env, or let `scripts/install.sh` create a secure one.
# The installer never rotates or overwrites an existing secret.

COMPOSE_PROJECT_NAME=rsctf
COMPOSE_FILE=compose.yml

# Published rsctf full-stack image (Rust server plus the built web client).
RSCTF_IMAGE=dimasmaualana/rsctf:latest
# Keep `all` for the normal one-container deployment. compose.roles.yml
# overrides the public service to `web` and adds one `control` owner. Before
# selecting that overlay, replace `latest` above with one reviewed version tag
# and keep the exact value unchanged across migration, web, and control.
RSCTF_ROLE=all

POSTGRES_USER=rsctf
POSTGRES_DB=rsctf
POSTGRES_PASSWORD=change-me-in-production
RSCTF_JWT_SECRET=change-me-in-production

# Safe local-only defaults. Production should use an https:// URL and true.
RSCTF_PUBLIC_URL=http://localhost:8080
RSCTF_COOKIE_SECURE=false
RSCTF_HTTP_BIND_IP=127.0.0.1
RSCTF_HTTP_PORT=8080
# Exact static address used only by the optional Caddy override. In local mode
# no peer has this address, so forwarded headers remain untrusted.
RSCTF_TRUSTED_PROXY_CIDRS=172.31.252.2/32

RUST_LOG=info
REDIS_MAXMEMORY=256mb
# Per-role connection caps must cover nested repository/provisioning locks. With
# R=1 and P=4, web needs 13, non-VPN control needs 15, and VPN control needs 18.
RSCTF_DB_MAX_CONNECTIONS=32
RSCTF_WEB_DB_MAX_CONNECTIONS=13
RSCTF_CONTROL_DB_MAX_CONNECTIONS=20
RSCTF_PROVISIONING_CONCURRENCY=4
RSCTF_REPO_SCAN_CONCURRENCY=1
RSCTF_CONTAINER_MAX_MEMORY_MB=4096
RSCTF_CONTAINER_MAX_CPU_COUNT=8
# Packet capture is disabled unless the topology-specific capture overlay is
# selected. The overlay sets this true and grants only its owner NET_RAW.
RSCTF_TRAFFIC_CAPTURE_ENABLED=false
RSCTF_CAPTURE_DEVICE=any
RSCTF_CAPTURE_RECONCILE_SECONDS=2
# Reserve these otherwise-unused numeric identities for checker subprocesses.
# The PID cgroup remains the aggregate fork backstop.
RSCTF_CHECKER_UID_BASE=60000
RSCTF_CHECKER_PROCESS_BUDGET=32
RSCTF_APP_PIDS_LIMIT=1024

# Shared blob storage. Local remains the single-host default. S3 covers
# content-addressed blobs; split/multi-host installs still need a shared
# RSCTF_STORAGE_ROOT for repository worktrees, captures, and checker artifacts.
RSCTF_STORAGE_BACKEND=local
RSCTF_S3_BUCKET=
RSCTF_S3_REGION=
RSCTF_S3_ENDPOINT=
RSCTF_S3_PREFIX=assets
RSCTF_S3_ACCESS_KEY=
RSCTF_S3_SECRET_KEY=

# Docker challenge backend (add compose.docker.yml to COMPOSE_FILE).
RSCTF_DOCKER_PUBLIC_ENTRY=localhost
# compose.docker.yml acknowledges that its scaled replicas share this host's
# one daemon. Do not set this for Kubernetes or independent node-local daemons.
# RSCTF_SHARED_DOCKER_DAEMON=true

# Caddy automatic HTTPS (add compose.caddy.yml to COMPOSE_FILE).
RSCTF_DOMAIN=ctf.example.com
RSCTF_PROXY_SUBNET=172.31.252.0/24
RSCTF_CADDY_IP=172.31.252.2
# Caddy resolves the stable rsctf-network alias dynamically. The role override
# moves that alias from the all-in-one process to the control process.
RSCTF_NETWORK_UPSTREAM_HOST=rsctf-network
RSCTF_NETWORK_UPSTREAM_PORT=8080

# Trusted outbound worker plane. Add compose.workers.yml for an all-in-one
# deployment, or compose.roles.workers.yml after compose.roles.yml. These files
# are intentionally not selected by the guided installer because they require
# a separately generated private CA and server certificate.
RSCTF_WORKER_PUBLIC_ENDPOINT=workers.ctf.example.com:9443
RSCTF_WORKER_SERVER_NAME=workers.ctf.example.com
RSCTF_WORKER_BIND_IP=0.0.0.0
RSCTF_WORKER_PORT=9443
# Keep none for pure remote mode. Select docker only when the Docker socket
# overlay is merged before the worker overlay in an all-in-one deployment; add
# compose.capture.yml last when local packet capture is also required. Split
# worker mode is remote-only until local lifecycle requests can be delegated
# safely. Kubernetes local mode is for an all-in-one in-cluster Helm deployment.
RSCTF_WORKER_LOCAL_BACKEND=none
# Fallback OCI platform for portable images launched through the existing
# one-container API. The shipped worker agent/runtime is Linux-only; keep the
# OS set to linux and set the architecture to match the Linux worker fleet.
# Do not change these defaults to Windows: Windows protocol fields are reserved
# for a future runtime, and v1 ships no native Windows workload artifact.
RSCTF_WORKER_DEFAULT_OS=linux
RSCTF_WORKER_DEFAULT_ARCH=amd64
RSCTF_WORKER_CA_CERT_HOST=./worker-secrets/worker-ca.crt
RSCTF_WORKER_CA_KEY_HOST=./worker-secrets/worker-ca.key
RSCTF_WORKER_SERVER_CERT_HOST=./worker-secrets/worker-server.crt
RSCTF_WORKER_SERVER_KEY_HOST=./worker-secrets/worker-server.key

# A&D VPN (add compose.ad-vpn.yml to COMPOSE_FILE; it includes Docker support).
RSCTF_AD_VPN_SERVICES_NETWORK=rsctf-ad
RSCTF_AD_VPN_CLIENT_CIDR=10.13.0.0/19
RSCTF_AD_VPN_SERVICES_CIDR=10.13.40.0/24
RSCTF_AD_VPN_SERVER_ENDPOINT=ctf.example.com:51820
RSCTF_AD_VPN_PORT=51820
RSCTF_AD_SSH_PORT=2222
