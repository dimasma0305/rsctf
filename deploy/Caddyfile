{
	admin off
}

{$RSCTF_DOMAIN} {
	encode zstd gzip

	# BYOC agents and BYOC admin terminals depend on process-local tunnel state;
	# KotH recovery must execute beside the checker firewall owner.
	# The rsctf-network alias belongs to rsctf in single-role mode and is moved
	# to rsctf-control by compose.roles.yml. Resolve it for every request so a
	# recreated singleton cannot leave Caddy pinned to a stale container address.
	@network path_regexp network ^(?:/api/(?:stateful/)?Game/[0-9]+/Ad/Byoc/(?:Agent|Image)/.*|/api/stateful/edit/games/[1-9][0-9]*/ad/koth/[1-9][0-9]*/recover|/api/edit/games/[1-9][0-9]*/ad/koth/[1-9][0-9]*/recover|/api/proxy(?:/.*)?|/api/workers/enroll|/api/admin/workers(?:/.*)?|/hub/containerExec(?:/games/[1-9][0-9]*)?(?:/negotiate)?)$
	# Agent/Image URLs contain bearer capabilities in their path. Never write
	# those request URIs to the access log.
	@byocCapability path_regexp byocCapability ^/api/(?:stateful/)?Game/[0-9]+/Ad/Byoc/(?:Agent|Image)/.*$
	log_skip @byocCapability
	# SignalR WebSocket clients carry their bearer in the access_token query.
	# Exclude hub request URIs so proxy logs cannot retain that credential.
	@hubBearer path /hub/*
	log_skip @hubBearer
	handle @network {
		reverse_proxy {
			dynamic a {$RSCTF_NETWORK_UPSTREAM_HOST:rsctf-network} {$RSCTF_NETWORK_UPSTREAM_PORT:8080} {
				refresh 1s
				resolvers 127.0.0.11
				versions ipv4
			}
			lb_try_duration 3s
			lb_try_interval 100ms
			transport http {
				dial_timeout 500ms
				# Stateful traffic is low-volume or long-lived. A fresh upstream
				# connection prevents stale pooled sockets from turning its POST
				# mutations into proxy-generated 502s.
				keepalive off
			}
		}
	}
	# Go safely retries idempotent reads when an HTTP/1.1 upstream closes a
	# pooled idle connection, but deliberately returns 502 for mutations because
	# their commit state is ambiguous. Give ordinary API mutations a fresh
	# upstream connection instead of retrying them or risking stale-pool reuse.
	@mutation method POST PUT PATCH DELETE
	handle @mutation {
		reverse_proxy {
			dynamic a rsctf 8080 {
				refresh 1s
				resolvers 127.0.0.11
				versions ipv4
			}
			lb_policy random_choose 2
			lb_try_duration 3s
			lb_try_interval 100ms
			transport http {
				dial_timeout 500ms
				keepalive off
			}
		}
	}
	handle {
		# Resolve the Compose service on every proxy selection. A static hostname
		# may be resolved only when Caddy loads its config, which would pin a
		# scaled service to one container and retain stale addresses after a
		# scale-down. Docker DNS returns every live `rsctf` replica here.
		reverse_proxy {
			dynamic a rsctf 8080 {
				# Docker's embedded DNS changes immediately when replicas leave,
				# while Caddy's A-record cache otherwise lives for one minute.
				refresh 1s
				resolvers 127.0.0.11
				versions ipv4
			}
			lb_policy random_choose 2
			lb_try_duration 3s
			lb_try_interval 100ms
			# A removed container address can silently drop SYNs. Fail that dial
			# soon enough to resolve the fresh replica set and retry the request.
			transport http {
				dial_timeout 500ms
				# Limit stale idle sockets; idempotent requests are retried safely.
				keepalive 30s
			}
		}
	}

	header {
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}

	log {
		output stdout
		format console
	}
}
